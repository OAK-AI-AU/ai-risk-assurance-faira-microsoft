{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OAK-AI-Public/ai-risk-assurance-faira-microsoft/schemas/vaiss-guardrails.schema.json",
  "title": "VAISS 10 Guardrails Assessment",
  "description": "Schema for Voluntary AI Safety Standard (VAISS) 10 guardrails assessment",
  "type": "object",
  "required": ["metadata", "guardrailAssessments"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "assessmentDate", "organisation"],
      "properties": {
        "version": {
          "type": "string",
          "description": "VAISS version",
          "enum": ["1.0", "2.0", "2.1"]
        },
        "schemaVersion": {
          "type": "string",
          "description": "Schema version for migration support",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "1.0.0"
        },
        "assessmentDate": {
          "type": "string",
          "format": "date"
        },
        "organisation": {
          "type": "string"
        },
        "assessor": {
          "type": "object",
          "properties": {
            "name": {"type": "string"},
            "role": {"type": "string"},
            "email": {"type": "string", "format": "email"}
          }
        },
        "aiSystemName": {
          "type": "string",
          "description": "AI system being assessed"
        },
        "organisationType": {
          "type": "string",
          "enum": ["AI Deployer", "AI Developer", "Both"]
        }
      }
    },
    "v2Enhancements": {
      "type": "object",
      "description": "VAISS v2 enhanced capabilities (optional, for v2.0+ assessments)",
      "properties": {
        "contentProvenance": {
          "type": "object",
          "description": "C2PA content provenance compliance",
          "properties": {
            "implemented": {"type": "boolean"},
            "c2paCompliant": {"type": "boolean", "description": "Coalition for Content Provenance and Authenticity compliance"},
            "provenanceTracking": {"type": "boolean"},
            "contentAuthentication": {"type": "boolean"},
            "evidence": {"type": "string"}
          }
        },
        "watermarking": {
          "type": "object",
          "description": "AI content watermarking capabilities",
          "properties": {
            "implemented": {"type": "boolean"},
            "visibleWatermark": {"type": "boolean"},
            "invisibleWatermark": {"type": "boolean"},
            "robustToModification": {"type": "boolean"},
            "detectionToolAvailable": {"type": "boolean"},
            "evidence": {"type": "string"}
          }
        },
        "developerGuardrails": {
          "type": "object",
          "description": "Enhanced developer-focused guardrails",
          "properties": {
            "secureByDesign": {"type": "boolean"},
            "privacyByDesign": {"type": "boolean"},
            "redTeamingConducted": {"type": "boolean"},
            "modelCardProvided": {"type": "boolean"},
            "dataSheetProvided": {"type": "boolean"},
            "safetyEvaluation": {"type": "boolean"},
            "harmMitigation": {"type": "boolean"}
          }
        },
        "nationalAICapabilityPlanAlignment": {
          "type": "object",
          "description": "Alignment with National AI Capability Plan",
          "properties": {
            "aligned": {"type": "boolean"},
            "capabilitiesSupported": {
              "type": "array",
              "items": {"type": "string"}
            },
            "sovereignAIConsiderations": {"type": "boolean"}
          }
        },
        "generativeAISpecific": {
          "type": "object",
          "description": "GenAI-specific v2 requirements",
          "properties": {
            "outputDisclosure": {"type": "boolean", "description": "Clear disclosure that content is AI-generated"},
            "hallucinationMitigation": {"type": "boolean"},
            "copyrightCompliance": {"type": "boolean"},
            "harmfulContentFiltering": {"type": "boolean"},
            "promptInjectionProtection": {"type": "boolean"}
          }
        }
      }
    },
    "guardrailAssessments": {
      "type": "array",
      "description": "Assessment of all 10 VAISS guardrails",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["guardrailNumber", "guardrailName", "implementationStatus"],
        "properties": {
          "guardrailNumber": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "guardrailName": {
            "type": "string",
            "enum": [
              "Accountability and Governance",
              "Risk Management",
              "Data Governance and Protection",
              "Testing and Monitoring",
              "Human Oversight",
              "Transparency",
              "Contestability",
              "Supply Chain Transparency",
              "Compliance",
              "Stakeholder Engagement"
            ]
          },
          "implementationStatus": {
            "type": "string",
            "enum": ["Not Implemented", "Partially Implemented", "Largely Implemented", "Fully Implemented"]
          },
          "requirements": {
            "type": "array",
            "description": "Specific requirements within this guardrail",
            "items": {
              "type": "object",
              "properties": {
                "requirementId": {"type": "string"},
                "description": {"type": "string"},
                "implemented": {"type": "boolean"},
                "evidence": {"type": "string"},
                "notes": {"type": "string"}
              }
            }
          },
          "gaps": {
            "type": "array",
            "description": "Identified gaps in implementation",
            "items": {
              "type": "object",
              "properties": {
                "gap": {"type": "string"},
                "severity": {"type": "string", "enum": ["Low", "Medium", "High", "Critical"]},
                "remediationPlan": {"type": "string"},
                "targetDate": {"type": "string", "format": "date"}
              }
            }
          },
          "controls": {
            "type": "array",
            "description": "Controls addressing this guardrail",
            "items": {
              "type": "string",
              "pattern": "^CTRL-\\d{4}$"
            }
          },
          "evidence": {
            "type": "array",
            "description": "Evidence of compliance",
            "items": {
              "type": "object",
              "properties": {
                "type": {"type": "string", "enum": ["Document", "Process", "System", "Audit", "Testing", "Training"]},
                "description": {"type": "string"},
                "location": {"type": "string"},
                "lastVerified": {"type": "string", "format": "date"}
              }
            }
          },
          "responsibleParty": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "role": {"type": "string"},
              "department": {"type": "string"}
            }
          },
          "alignmentWithOtherFrameworks": {
            "type": "object",
            "properties": {
              "iso42001": {"type": "array", "items": {"type": "string"}},
              "nistAIRMF": {"type": "array", "items": {"type": "string"}},
              "faira": {"type": "array", "items": {"type": "string"}},
              "nfaaig": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "overallAssessment": {
      "type": "object",
      "properties": {
        "maturityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall VAISS maturity score"
        },
        "implementationLevel": {
          "type": "string",
          "enum": ["Emerging", "Developing", "Implementing", "Leading"]
        },
        "strengths": {
          "type": "array",
          "items": {"type": "string"}
        },
        "priorityAreas": {
          "type": "array",
          "description": "Priority areas for improvement",
          "items": {
            "type": "object",
            "properties": {
              "guardrail": {"type": "integer", "minimum": 1, "maximum": 10},
              "priority": {"type": "string", "enum": ["Low", "Medium", "High", "Critical"]},
              "action": {"type": "string"}
            }
          }
        },
        "nextReviewDate": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "actionPlan": {
      "type": "array",
      "description": "Action plan for improvement",
      "items": {
        "type": "object",
        "properties": {
          "guardrail": {"type": "integer", "minimum": 1, "maximum": 10},
          "action": {"type": "string"},
          "owner": {"type": "string"},
          "dueDate": {"type": "string", "format": "date"},
          "status": {"type": "string", "enum": ["Not Started", "In Progress", "Completed", "Deferred"]},
          "resources": {"type": "string"}
        }
      }
    }
  }
}
